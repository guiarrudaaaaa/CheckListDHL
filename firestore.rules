rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Checklists: usuários podem criar anonimamente, mas apenas autenticados podem ler/deletar
    match /checklists/{document} {
      allow create: if true;  // Permite criar novos checklists anonimamente
      allow read, delete: if request.auth != null;  // Apenas autenticados podem ler/deletar
    }

    // Bloqueia tudo o resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}